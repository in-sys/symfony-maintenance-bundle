{
    "name": "in-sys/symfony-maintenance-bundle",
    "type": "symfony-bundle",
    "description": "This bundle allows you to place your website in maintenance mode by calling two commands from your console. Symfony 6.4 / 7",
    "homepage": "https://github.com/in-sys/symfony-maintenance-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "INSYS",
            "email": "contact@insys.email"
        },
        {
            "name": "Gilles Gauthier",
            "email": "g.gauthier@lexik.fr"
        },
        {
            "name": "Dev Lexik",
            "email": "dev@lexik.fr"
        },
        {
            "name": "Djuri Baars",
            "email": "info@djurict.nl"
        }
    ],
    "require": {
        "php": "^8.1",
        "symfony/console": "^6.4||^7.0",
        "symfony/framework-bundle": "^6.4||^7.0",
        "symfony/translation": "^6.4||^7.0",
        "symfony/translation-contracts": "^3.0"
    },
    "require-dev": {
        "doctrine/dbal": "^3.6||^4.0",
        "doctrine/orm": "^2.14||^3.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.0||^11.0"
    },
    "autoload": {
        "psr-4": {
            "INSYS\\Bundle\\MaintenanceBundle\\": ""
        }
    },
    "config": {
        "audit": {
            "abandoned": "report",
            "block-insecure": false
        }
    },
    "scripts": {
        "unit-tests": [
            "vendor/bin/phpunit"
        ]
    },
    "version": "2.0.0"
}
